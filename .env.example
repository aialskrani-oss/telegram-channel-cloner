# ==========================================
# إعدادات Telegram Channel Cloner
# ==========================================

# 🔑 بيانات تطبيق Telegram (من my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# 🔐 جلسة تيليجرام (شغّل البوت مرة أولى بدونه لتوليده)
SESSION_STRING=

# 📡 معرّف القناة المصدر (مثال: @mychannel أو -1001234567890)
SOURCE_CHANNEL=@source_channel

# 📥 معرّف القناة الهدف (مثال: @mychannel أو -1001234567890)
DESTINATION_CHANNEL=@destination_channel

# ⚙️ إعدادات الأداء (اختياري)
BATCH_SIZE=50
DELAY_BETWEEN_MESSAGES=0.5
DELAY_BETWEEN_BATCHES=2.0
MAX_RETRIES=5
RETRY_DELAY=10.0
DB_PATH=/data/cloner.db
