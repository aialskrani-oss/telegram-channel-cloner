# =============================================
# بوت نسخ قنوات تيليجرام — الإعدادات
# =============================================

# 🤖 رمز البوت — من @BotFather
BOT_TOKEN=your_bot_token_here

# 📡 القناة المصدر (اختياري — يمكن تعيينه بأمر /setsource)
# مثال: @mychannel أو -1001234567890
SOURCE_CHANNEL=

# 📥 القناة الهدف (اختياري — يمكن تعيينه بأمر /setdest)
# مثال: @mychannel2 أو -1001234567891
DESTINATION_CHANNEL=

# 👤 معرّفات المشرفين (اختياري — افصل بفاصلة)
# مثال: 123456789,987654321
ADMIN_IDS=

# 💾 مسار قاعدة البيانات
DB_PATH=/data/cloner.db
